# ── Judge：DeepSeek API（复用兄弟项目约定）──
DEEPSEEK_API_KEY=your_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT=60
DEEPSEEK_MAX_RETRIES=3

# ── 被测候选：后端选择（ollama|openai|siliconflow|litellm；默认 ollama）──
# CANDIDATE_BACKEND=ollama

# ── 候选后端 ollama：本地 Ollama 原生 REST /api/generate ──
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_TIMEOUT=600
# DUT 思考开关（推理模型如 qwen3.5）：on|off；留空=用模型默认。
# off 可把 qwen3.5 从 ~147s/条 提到 ~15s/条（代价：欠测 MedCOT/MedReflect 等推理类任务）。
# 也可用 eval.sh --think on|off 覆盖。
# OLLAMA_THINK=off

# ── 候选后端 openai：任意 OpenAI-compatible /v1/chat/completions ──
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=your_key_here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT=300

# ── 候选后端 siliconflow：siliconflow.cn（OpenAI-compatible 协议）──
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_API_KEY=your_key_here

# ── 候选后端 litellm：本地 LiteLLM proxy（OpenAI-compatible 协议；无鉴权时 key 可留空）──
# LITELLM_BASE_URL=http://localhost:4000/v1
# LITELLM_API_KEY=
